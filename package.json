{
  "name": "telegram-rich-messages",
  "version": "0.1.0",
  "description": "Compose Telegram Bot API rich messages with typed functions, fluent builders, and TSX",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js"
    },
    "./fluent": {
      "types": "./dist/fluent.d.ts",
      "import": "./dist/fluent.js"
    },
    "./jsx/jsx-runtime": {
      "types": "./dist/components/jsx-runtime.d.ts",
      "import": "./dist/components/jsx-runtime.js"
    },
    "./jsx/jsx-dev-runtime": {
      "types": "./dist/components/jsx-runtime.d.ts",
      "import": "./dist/components/jsx-runtime.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "bun run build && tsc --noEmit && bun test",
    "test": "bun run build && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "keywords": ["telegram", "bot-api", "rich-message", "tsx", "jsx"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/roziscoding/telegram-rich-messages.git"
  },
  "homepage": "https://github.com/roziscoding/telegram-rich-messages#readme",
  "bugs": {
    "url": "https://github.com/roziscoding/telegram-rich-messages/issues"
  },
  "dependencies": {
    "@grammyjs/types": "4.0.0"
  },
  "peerDependencies": {
    "grammy": "^1.45.1"
  }
}
